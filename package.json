{
  "name": "nexus-rmm",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @nexus/protocol build && pnpm --filter @nexus/server dev",
    "infra:up": "docker compose --env-file .env -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose --env-file .env -f infra/docker-compose.yml down",
    "infra:logs": "docker compose --env-file .env -f infra/docker-compose.yml logs -f",
    "db:generate": "pnpm --filter @nexus/server db:generate",
    "db:migrate": "pnpm --filter @nexus/server db:migrate",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter @nexus/server test"
  }
}
