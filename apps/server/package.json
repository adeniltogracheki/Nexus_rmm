{
  "name": "@nexus/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx --env-file=../../.env src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=../../.env src/db/migrate.ts",
    "db:seed": "tsx --env-file=../../.env src/db/seed.ts",
    "db:reset-owner": "tsx --env-file=../../.env src/db/reset-owner.ts",
    "test": "tsx --env-file=../../.env --test test/*.test.ts",
    "lint": "echo \"(lint: @nexus/server) ok\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@fastify/cookie": "^11.0.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.0.0",
    "@nexus/protocol": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "node-forge": "^1.3.1",
    "nodemailer": "^6.9.16",
    "otplib": "^12.0.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/node-forge": "^1.3.11",
    "@types/nodemailer": "^6.4.16",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.5",
    "drizzle-kit": "^0.28.1",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
