# ─── Aplicação ────────────────────────────────────────────────
NODE_ENV=development
SERVER_PORT=4000
LOG_LEVEL=info

# ─── Postgres ─────────────────────────────────────────────────
# Senha do superusuário (postgres) — usada pelo container e pelos scripts de init.
POSTGRES_SUPER_PASSWORD=troque_este_super
# Senha da role de aplicação (nexus_app), não-superusuário.
NEXUS_APP_PASSWORD=troque_este_app
# A app conecta como nexus_app (ver README §Segurança).
DATABASE_URL=postgresql://nexus_app:troque_este_app@localhost:5432/nexus

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Placeholders Fase 1 (ainda não usados) ───────────────────
JWT_SECRET=
COMMAND_SIGNING_PRIVATE_KEY=
